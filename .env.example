# Copy this file to ".env" in the project root and fill in secrets.
# .env is gitignored — never commit real passwords.

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Production HTTPS (comma-separated):
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Local PostgreSQL (used when DATABASE_URL is not set)
POSTGRES_DB=warewolf
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production: set in cloud dashboard (Render injects this when DB is linked)
# DATABASE_URL=postgres://...

# Redis / Celery (Render injects REDIS_URL for Redis add-on)
# REDIS_URL=redis://127.0.0.1:6379/0

# Optional: require SSL for Postgres when using DATABASE_URL without sslmode in URL
# DJANGO_DATABASE_SSL_REQUIRE=true

# ---------------------------------------------------------------------------
# Real email (SMTP) — required for sending mail to users’ addresses
# ---------------------------------------------------------------------------
# With EMAIL_HOST_PASSWORD set, Django uses real SMTP (not the console).
#
# Gmail example:
# 1. Google Account → Security → 2-Step Verification (must be on).
# 2. App passwords → create an app password for "Mail" / "Other (WareWolf)".
# 3. Paste the 16-character app password below (spaces optional).
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=youraddress@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=WareWolf <youraddress@gmail.com>

# Other providers: set EMAIL_HOST / EMAIL_PORT / TLS to match their docs.
# For production (Render etc.), set the same variables in the service Environment.
